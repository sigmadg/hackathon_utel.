# Django
DEBUG=1
DJANGO_SECRET_KEY=dev-secret-cambiar-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1

# LLM (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama local (si lo usas, el prototipo usará este modelo en lugar de OpenAI)
OLLAMA_MODEL=qwen2.5-coder:1.5b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Agente LangChain (tools + LLM): cuando hay copia del template, usa herramientas para aplicar diseño/integraciones
# USE_LANGCHAIN_AGENT=true

# Tiendanube (opcional para prototipo)
# Opción 1: OAuth (recomendado). Define APP_ID, CLIENT_SECRET y la URL de redirección de tu app en el panel de partners.
TIENDANUBE_APP_ID=
TIENDANUBE_CLIENT_SECRET=
# URL exacta configurada en "URL de redirección" al instalar la app (ej: http://localhost:8000/oauth/tiendanube/callback/)
TIENDANUBE_REDIRECT_URI=
# Opcional: https://www.tiendanube.com o https://www.nuvemshop.com.br
TIENDANUBE_OAUTH_DOMAIN=https://www.tiendanube.com

# Opción 2: Token manual (después de obtenerlo por OAuth o para pruebas)
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_STORE_ID=
TIENDANUBE_API_BASE=https://api.tiendanube.com/2025-03
